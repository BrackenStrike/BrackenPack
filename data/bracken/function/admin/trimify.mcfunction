$item replace entity @s armor.head with $(material)_helmet[trim={material:"$(trim_material)",pattern:"$(pattern)"}]
$item replace entity @s armor.chest with $(material)_chestplate[trim={material:"$(trim_material)",pattern:"$(pattern)"}]
$item replace entity @s armor.legs with $(material)_leggings[trim={material:"$(trim_material)",pattern:"$(pattern)"}]
$item replace entity @s armor.feet with $(material)_boots[trim={material:"$(trim_material)",pattern:"$(pattern)"}]